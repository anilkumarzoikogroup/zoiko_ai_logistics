# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=postgresql://postgres:YOUR_PASSWORD@localhost/zoiko

# ── Auth / Security ───────────────────────────────────────────────────────────
ZOIKO_DEV_MODE=true
ZOIKO_DEV_SECRET=zoiko-dev-secret-for-testing-only
ZOIKO_ISSUER=https://auth.zoikotech.com

# ── Service URLs ──────────────────────────────────────────────────────────────
PHASE2_API_URL=http://localhost:8000
PHASE3_API_URL=http://localhost:8002
PHASE4_API_URL=http://localhost:8001

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092

# ── OPA Policy Engine ─────────────────────────────────────────────────────────
OPA_URL=

# ── Governance Token ──────────────────────────────────────────────────────────
TOKEN_TTL_MINUTES=15

# ── Python / Windows ──────────────────────────────────────────────────────────
PYTHONIOENCODING=utf-8
