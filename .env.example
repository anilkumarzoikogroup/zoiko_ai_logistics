# Copy this file to .env and fill in real values before running.
# NEVER commit .env to git — it is already in .gitignore.

# -- Database ------------------------------------------------------------------
DB_URL=postgresql://postgres:CHANGE_ME@localhost/zoiko
DB_POOL_MIN=2
DB_POOL_MAX=10

# -- Auth / Security -----------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ZOIKO_DEV_SECRET=CHANGE_ME_USE_SECRETS_TOKEN_HEX_32
ZOIKO_ISSUER=https://auth.yourdomain.com
JWT_TTL_SECONDS=86400
ZOIKO_FF_SC_001_ENABLED=*
ZOIKO_CORS_ORIGINS=https://yourdomain.com

# -- Company / First-run admin -------------------------------------------------
ZOIKO_COMPANY_NAME=Your Company Name
ZOIKO_ADMIN_EMAIL=admin@yourcompany.com
ZOIKO_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ZOIKO_ADMIN_NAME=Platform Admin

# -- Service URLs --------------------------------------------------------------
PHASE2_API_URL=http://localhost:8000
PHASE3_API_URL=http://localhost:8002
PHASE4_API_URL=http://localhost:8001

# -- Redis ---------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -- Kafka ---------------------------------------------------------------------
# Leave empty to use in-memory mock (dev). Set to use real Kafka in prod.
KAFKA_BOOTSTRAP=

# -- OPA Policy Engine ---------------------------------------------------------
OPA_URL=

# -- Governance Token ----------------------------------------------------------
# 15 min for production, 1440 (24h) for development/testing
TOKEN_TTL_MINUTES=15

# -- Rate limiting -------------------------------------------------------------
ZOIKO_RATE_LIMIT_ENABLED=true
RATE_LIMIT_INGESTION=100
RATE_LIMIT_GOVERNANCE=20
RATE_LIMIT_EXECUTION=10

# -- Upload limits ------------------------------------------------------------
MAX_UPLOAD_BYTES=10485760   # 10 MB per file
BATCH_MAX_FILES=20          # max files per batch upload

# -- AI (Groq) — get free key at https://console.groq.com ---------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# -- Email (password reset + invitations) -------------------------------------
# Provider: sendgrid | smtp | none (logs tokens only)
EMAIL_PROVIDER=none
EMAIL_NAME=noreply@yourcompany.com
EMAIL_PASSWORD=CHANGE_ME_STRONG_PASSWORD # Generate through gamil app password

# -- Python / Windows ----------------------------------------------------------
PYTHONIOENCODING=utf-8
