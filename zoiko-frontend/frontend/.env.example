# Copy this file to .env.local and edit values for your setup.

# Set to "false" to talk to the real backend; "true" (or unset) uses mock data.
VITE_USE_MOCK=true

# Backend base URL (used when VITE_USE_MOCK=false).
# In dev, /api is also proxied to http://localhost:8000 via vite.config.ts.
VITE_API_BASE=/api

# Development JWT and tenant slug.
# In production these come from your auth login flow, not env vars.
VITE_DEV_JWT=
VITE_DEV_TENANT=amazon-india
